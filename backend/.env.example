# Server Configuration
PORT=8000
NODE_ENV=development
ENABLE_SOCKET_IO=false
SENTRY_DSN=

# Database
MONGODB_URI=<required_mongodb_connection_uri>
# Optional alias supported by verify script
DB_URI=
MONGO_URI=

# Authentication
JWT_SECRET=<required_strong_random_jwt_secret>
BCRYPT_ROUNDS=10


# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app


# Optional demo seeding (disabled by default)
ENABLE_DEMO_SEEDING=false
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_ROLE=Admin

# File Upload
UPLOAD_DIR=uploads
